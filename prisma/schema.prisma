generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  stock     Int?
  status    String   @default("active")
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@map("products")
}
